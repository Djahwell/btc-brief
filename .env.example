# ─── BTC Morning Brief — API Keys ────────────────────────────────────────────
# Copy this file to .env and fill in your real keys.
# .env is git-ignored by default (add it to .gitignore if you version this repo).

# Tiingo — price / OHLCV data
# https://www.tiingo.com/account/api/token
VITE_TIINGO_TOKEN=

# Nansen — on-chain whale / exchange flow intelligence
# https://app.nansen.ai/api
VITE_NANSEN_API_KEY=

# Anthropic — Claude inference (used server-side via Vite proxy, never sent to browser)
# https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=sk-ant-...

# ─── Notes ───────────────────────────────────────────────────────────────────
# CoinGecko, Binance, Coinglass, Alternative.me are free/public — no key needed.
# The Anthropic key is forwarded by the Vite dev-server proxy and is NOT
# bundled into the browser JS, but treat it as a secret anyway.
