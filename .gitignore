# Environment — contains real API keys, NEVER commit this
.env
env.env
*.textClipping

# Dependencies
node_modules/

# Build output
dist/
android-build/

# OS
.DS_Store

# Vite — auto-generated config timestamp files
*.local
*.timestamp-*.mjs

# Android bug reports (often >MB and never want to commit)
bugreport-*.zip

# Project backups (kept locally, never pushed)
/backups/

# Snapshot history is built fresh in CI from gh-pages, never committed to main.
# (data-refresh.yml seeds it from the gh-pages branch, snapshots, and redeploys.)
/public/history/
